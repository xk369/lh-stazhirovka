# Token of the same Telegram bot that opens this Mini App in PuzzleBot.
BOT_TOKEN=123456789:replace_me

# Telegram supergroup IDs. The backend selects the report group strictly by role.
# For a server copy, put the test/report-copy group ID here before production rollout.
TRAINEE_CHAT_ID=-1000000000001
MENTOR_CHAT_ID=-1000000000002

# Username is shown only in the booking UI hint for Telegram notifications.
TELEGRAM_BOT_USERNAME=LOFT_HELPER_V2_BOT

# Persistent booking dates/applications database.
DATA_DIR=./data

# Keep "no" when the bot is connected to PuzzleBot.
TELEGRAM_POLLING=no

# A checklist may stay open during a long shift, so the default is 24 hours.
INIT_DATA_TTL_SECONDS=86400

HOST=0.0.0.0
PORT=3000
